#!/usr/bin/env bash
#
# Wrapper that ensures the correct Ruby (from .ruby-version) is used,
# regardless of which version manager is installed (rbenv, rvm, rv, mise,
# asdf, chruby, etc.). MCP clients like Claude Desktop launch processes
# with a minimal PATH that skips version manager shims.
#
# Inspired by Shopify/ruby-lsp's approach: find the version manager
# executable and let it run ruby with the correct environment, rather
# than trying to reconstruct GEM_HOME/GEM_PATH manually.
#
# Set RUBY_VERSION_MANAGER in .env to skip auto-detection:
#   auto (default), rv, rbenv, mise, asdf, rvm, chruby
#
set -euo pipefail

DIR="$(cd "$(dirname "$0")/.." && pwd)"
read -r REQUIRED_VERSION < "$DIR/.ruby-version"
RUBY_ARGS=(-r bundler/setup -r "./lib/outlook_mcp" -e "\$0='outlook-mcp'; OutlookMcp::CLI.start(ARGV)" -- "$@")

# Load RUBY_VERSION_MANAGER from .env (simple parser — no dependency on dotenv).
RUBY_VERSION_MANAGER="${RUBY_VERSION_MANAGER:-}"
if [[ -z "$RUBY_VERSION_MANAGER" && -f "$DIR/.env" ]]; then
  while IFS='=' read -r key val; do
    if [[ "$key" == "RUBY_VERSION_MANAGER" ]]; then
      RUBY_VERSION_MANAGER="${val//[[:space:]\"\'/]}"
      break
    fi
  done < "$DIR/.env"
fi
RUBY_VERSION_MANAGER="${RUBY_VERSION_MANAGER:-auto}"
RUBY_VERSION_MANAGER="$(printf '%s' "$RUBY_VERSION_MANAGER" | tr '[:upper:]' '[:lower:]')"

MANAGERS=(rv rbenv mise asdf rvm chruby)

# Exec into ruby with the correct working directory.
# Exports RUBY_VERSION_MANAGER so the Ruby process knows which manager was used.
run_ruby() {
  export RUBY_VERSION_MANAGER="${_DETECTED_MANAGER:-$RUBY_VERSION_MANAGER}"
  cd "$DIR"
  exec "$@" "${RUBY_ARGS[@]}"
}

# Check if `ruby` on PATH matches the required version.
current_ruby_matches() {
  command -v ruby >/dev/null 2>&1 || return 1
  local v
  v="$(ruby -e 'print RUBY_VERSION' 2>/dev/null)" || return 1
  [[ "$v" == "$REQUIRED_VERSION" ]]
}

# Find an executable in a list of directories, falling back to PATH.
find_exec() {
  local name="$1"; shift
  for dir in "$@"; do
    if [[ -x "$dir/$name" ]]; then
      echo "$dir/$name"
      return 0
    fi
  done
  command -v "$name" 2>/dev/null
}

# --- Version manager runners ---
# Each uses `exec` on success (replaces process) or returns 1.

try_rv() {
  local p; p="$(find_exec rv /opt/homebrew/bin /usr/local/bin /usr/bin)" || return 1
  run_ruby "$p" ruby run --
}

try_rbenv() {
  local p; p="$(find_exec rbenv /opt/homebrew/bin /usr/local/bin "$HOME/.rbenv/bin")" || return 1
  run_ruby "$p" exec ruby
}

try_mise() {
  local p; p="$(find_exec mise "$HOME/.local/bin" /opt/homebrew/bin /usr/bin)" || return 1
  run_ruby "$p" x -- ruby
}

try_asdf() {
  local p; p="$(find_exec asdf "$HOME/.asdf/bin" /opt/homebrew/bin /usr/local/bin)" || return 1
  run_ruby "$p" exec ruby
}

try_rvm() {
  local rvm_paths=(
    "$HOME/.rvm/bin/rvm-auto-ruby"
    "/usr/local/rvm/bin/rvm-auto-ruby"
    "/usr/share/rvm/bin/rvm-auto-ruby"
  )
  for rvm_ruby in "${rvm_paths[@]}"; do
    [[ -x "$rvm_ruby" ]] && run_ruby "$rvm_ruby"
  done
  return 1
}

try_chruby() {
  local gem_version="${REQUIRED_VERSION%.*}.0"
  local chruby_dirs=("$HOME/.rubies" "/opt/rubies")
  for chruby_dir in "${chruby_dirs[@]}"; do
    local ruby_bin="$chruby_dir/ruby-$REQUIRED_VERSION/bin/ruby"
    if [[ -x "$ruby_bin" ]]; then
      local ruby_prefix="$chruby_dir/ruby-$REQUIRED_VERSION"
      local default_gems="$ruby_prefix/lib/ruby/gems/$gem_version"
      local gem_home="$HOME/.gem/ruby/$gem_version"
      mkdir -p "$gem_home"
      export GEM_HOME="$gem_home"
      export GEM_PATH="$gem_home:$default_gems"
      export PATH="$gem_home/bin:$default_gems/bin:$ruby_prefix/bin:$PATH"
      run_ruby "$ruby_bin"
    fi
  done
  return 1
}

# Detect version manager from the ruby binary path.
detect_manager_from_ruby() {
  local ruby_path
  ruby_path="$(command -v ruby 2>/dev/null)" || return 1
  case "$ruby_path" in
    */.local/share/rv/*) echo "rv" ;;
    */.rbenv/*) echo "rbenv" ;;
    */.local/share/mise/*|*/.local/share/rtx/*) echo "mise" ;;
    */.asdf/*) echo "asdf" ;;
    */.rvm/*) echo "rvm" ;;
    */.rubies/*|*/opt/rubies/*) echo "chruby" ;;
    *) return 1 ;;
  esac
}

# Dispatch to version managers based on RUBY_VERSION_MANAGER setting.
try_managers() {
  if [[ "$RUBY_VERSION_MANAGER" == "auto" ]]; then
    for mgr in "${MANAGERS[@]}"; do
      _DETECTED_MANAGER="$mgr"
      "try_$mgr" 2>/dev/null || true
    done
  else
    _DETECTED_MANAGER="$RUBY_VERSION_MANAGER"
    "try_$RUBY_VERSION_MANAGER" 2>/dev/null || true
  fi
}

# Validate RUBY_VERSION_MANAGER early.
if [[ "$RUBY_VERSION_MANAGER" != "auto" ]]; then
  valid=false
  for mgr in "${MANAGERS[@]}"; do
    [[ "$RUBY_VERSION_MANAGER" == "$mgr" ]] && valid=true
  done
  if ! $valid; then
    echo "ERROR: Unknown RUBY_VERSION_MANAGER '$RUBY_VERSION_MANAGER'" >&2
    echo "Valid values: auto, $(printf '%s, ' "${MANAGERS[@]}" | sed 's/, $//')" >&2
    exit 1
  fi
fi

# --- Main ---

# Strategy 1: Current ruby on PATH already matches.
if current_ruby_matches; then
  _DETECTED_MANAGER="$(detect_manager_from_ruby 2>/dev/null)" || true
  run_ruby ruby
fi

# Strategy 2: Find version manager executable and let it run ruby.
try_managers

# Strategy 3: Source shell profiles to activate version manager shims,
# then retry strategies 1 and 2.
for rc in "$HOME/.zprofile" "$HOME/.zshrc" "$HOME/.bash_profile" "$HOME/.bashrc" "$HOME/.profile"; do
  if [[ -f "$rc" ]]; then
    source "$rc" 2>/dev/null || true
    # Re-check after each file — skip sourcing the rest once ruby is found.
    if current_ruby_matches; then
      _DETECTED_MANAGER="$(detect_manager_from_ruby 2>/dev/null)" || true
      run_ruby ruby
    fi
  fi
done

try_managers

# Nothing worked.
echo "ERROR: Could not find Ruby $REQUIRED_VERSION" >&2
echo "Searched:" >&2
echo "  - ruby on PATH ($(command -v ruby 2>/dev/null || echo 'not found'))" >&2
if [[ "$RUBY_VERSION_MANAGER" == "auto" ]]; then
  echo "  - Version managers: ${MANAGERS[*]}" >&2
else
  echo "  - Version manager: $RUBY_VERSION_MANAGER" >&2
fi
echo "" >&2
echo "Install Ruby $REQUIRED_VERSION with your version manager and try again." >&2
echo "Set RUBY_VERSION_MANAGER in .env to skip auto-detection." >&2
exit 1
