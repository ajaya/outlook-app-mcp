OUTLOOK_CLIENT_ID=your-azure-app-client-id
OUTLOOK_CLIENT_SECRET=your-azure-app-client-secret
OUTLOOK_TENANT_ID=common

# Ruby version manager to use for finding the correct Ruby.
# Values: auto, rv, rbenv, mise, asdf, rvm, chruby
# Default: auto (tries all version managers in order)
# RUBY_VERSION_MANAGER=auto
